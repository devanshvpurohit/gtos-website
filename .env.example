# ─── EmailJS Configuration ───────────────────────────────────────────────────
# Sign up free at https://www.emailjs.com and fill in these values:
#
# 1. Service ID  → Dashboard → Email Services → (connect your Gmail) → copy ID
# 2. Template ID → Email Templates → create a template with these variables:
#      {{from_name}}    {{from_email}}    {{company_name}}    {{company_size}}
#    Set "To Email" in the template to: devanshpurohit@gmail.com
# 3. Public Key  → Account → API Keys → Public Key
# ─────────────────────────────────────────────────────────────────────────────

VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
